{
  "name": "autoapp-front",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "dotenv -e .env.local -- node --import ./instrument.server.mjs ./node_modules/vite/bin/vite.js dev --port 3000",
    "build": "vite build && node -e \"require('node:fs').copyFileSync('instrument.server.mjs', 'dist/server/instrument.server.mjs')\"",
    "preview": "vite preview",
    "test": "vitest run",
    "start": "node --import ./dist/server/instrument.server.mjs dist/server/server.js",
    "docs:api": "typedoc",
    "docs:api:json": "typedoc --json docs/api/typedoc.json"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@sentry/tanstackstart-react": "^10.42.0",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-query": "latest",
    "@tanstack/react-query-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "dotenv-cli": "^11.0.0",
    "lucide-react": "^0.545.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.74.0",
    "tailwindcss": "^4.1.18",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@tanstack/devtools-vite": "latest",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^28.1.0",
    "typedoc": "^0.28.19",
    "typescript": "^5.7.2",
    "vite": "^8.0.0",
    "vitest": "^3.0.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
